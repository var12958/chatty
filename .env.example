# Firebase Configuration for Production
# Get these values from Firebase Console → Project Settings → Web app
# https://console.firebase.google.com/project/{PROJECT_ID}/settings/general

# These variables are REQUIRED for the app to work
REACT_APP_FIREBASE_API_KEY=AIzaSyDxxx-xxxx_xxxx
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:xxxxx

# Optional: Backend API URL (for Netlify deployment, uncomment and update)
# REACT_APP_API_BASE_URL=https://api.example.com/api

# Development mode (set to false for production)
# REACT_APP_ENV=development

# Instructions for Netlify Deployment:
# 1. Push this repo to GitHub
# 2. Connect your GitHub repo to Netlify
# 3. In Netlify Site Settings → Environment variables
# 4. Add all REACT_APP_* variables from this file
# 5. Netlify will automatically build and deploy on each push
# 
# The build command is: CI=false npm run build
# The publish directory is: build/
