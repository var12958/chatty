# Firebase Configuration
# Get these values from: https://firebase.google.com/docs/web/setup
# 1. Go to Firebase Console → Your Project
# 2. Click Project Settings (⚙️ icon)
# 3. Scroll to "Your apps" section
# 4. Select/Create a Web app
# 5. Copy the config values below

REACT_APP_FIREBASE_API_KEY=YOUR_API_KEY_HERE
REACT_APP_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID_HERE
REACT_APP_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
REACT_APP_FIREBASE_APP_ID=YOUR_APP_ID_HERE

# Example (filled values look like this):
# REACT_APP_FIREBASE_API_KEY=AIzaSyDxxx-xxxx_xxxx
# REACT_APP_FIREBASE_AUTH_DOMAIN=my-project.firebaseapp.com
# REACT_APP_FIREBASE_PROJECT_ID=my-project
# REACT_APP_FIREBASE_STORAGE_BUCKET=my-project.appspot.com
# REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
# REACT_APP_FIREBASE_APP_ID=1:123456789:web:xxxxx
